  "keyFeatures": [
    "JWT-based authentication with bcrypt password hashing",
    "Gamification system: points and streaks awarded for task completions",
    "Challenge Templates catalog for structured multi-day challenges",
    "User Challenges: accept, track progress with notes, complete or abandon",
    "Daily task and routine management (CRUD)",
    "Scheduled cron jobs for overnight streak evaluation",
    "Controller-Service-Repository architecture pattern",
    "PostgreSQL database with Knex.js migrations and query building"
  ],
  "publicApiSurface": [
    "POST /api/auth/signup",
    "POST /api/auth/login",
    "GET /api/user/profile",
    "PUT /api/user/profile",
    "GET /api/challenge-templates",
    "GET /api/challenge-templates/:id",
    "POST /api/challenge-templates",
    "DELETE /api/challenge-templates/:id",
    "POST /api/user-challenges/accept",
    "GET /api/user-challenges/active",
    "GET /api/user-challenges",
    "PUT /api/user-challenges/:id/complete",
    "PUT /api/user-challenges/:id/abandon",
    "PUT /api/user-challenges/:id/notes",
    "POST /api/tasks",
    "GET /api/tasks/me",
    "PUT /api/tasks/:taskId",
    "DELETE /api/tasks/:taskId",
    "POST /api/task-completions"
  ]
